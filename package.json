    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.12",
    "@types/node": "^20.0.0",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "prisma": "^5.22.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
